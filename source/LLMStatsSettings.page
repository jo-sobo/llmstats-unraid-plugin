                <div class="llm-preview-prop" data-preview-field-cell="memory">
                  <span class="llm-preview-prop-label">Memory</span>
                  <span class="llm-preview-prop-value" data-preview-item="memory">4.9 GB</span>
                </div>
                <div class="llm-preview-prop" data-preview-field-cell="busy">
                  <span class="llm-preview-prop-label">State</span>
                  <span class="llm-preview-prop-value" data-preview-item="busy">Idle</span>
