<script type="text/javascript">
  (function($) {
    var servers = <?=$servers_js?>;
    var defaultFields = <?=$default_fields_js?>;
    var fieldOrder = <?=$field_order_js?>;
    var maxServers = <?=(int)llmstats_max_servers()?>;
    var selectedServer = servers.length > 0 ? servers[0] : null;
    var statusById = {};
    var testRequest = null;
    var llmstatsDirty = false;

    function llmstats_serialize() {
      var payload = servers.map(function(server) {
        var copy = $.extend(true, {}, server);
        var type = llmstats_effective_type(server);
        if (type !== '') {
          var supported = llmstats_supported_fields(server);
          copy.fields = (copy.fields || []).filter(function(field) {
            return supported.indexOf(field) !== -1;
          });
        }
        return copy;
      });
      $('#llmstats-servers-payload').val(JSON.stringify(payload));
    }

    function llmstats_type_label(type) {
      if (type === 'ollama') return 'Ollama';
      if (type === 'llama-server') return 'llama-server';
      return 'Unknown';
    }

    function llmstats_display_name(server) {
      return $.trim((server && server.name) || '') || 'New Server';
    }

    function llmstats_is_valid_url(url) {
      return /^https?:\/\/\S+$/i.test($.trim(url || ''));
    }

    function llmstats_server_issues(server) {
      var issues = {};
      if (!server) return issues;
      if ($.trim(server.name || '') === '') issues.name = true;
      if (!llmstats_is_valid_url(server.url || '')) issues.url = true;
      if (['auto', 'ollama', 'llama-server'].indexOf(server.type || 'auto') === -1) issues.type = true;
      return issues;
    }

    function llmstats_has_issues(server) {
      return Object.keys(llmstats_server_issues(server)).length > 0;
    }

    function llmstats_has_invalid_servers() {
      return servers.some(function(server) {
        return llmstats_has_issues(server);
      });
    }

    function llmstats_effective_type(server) {
      if (!server) return '';
      if (server.type === 'ollama' || server.type === 'llama-server') return server.type;

      var status = statusById[server.id];
      if (status && (status.type === 'ollama' || status.type === 'llama-server')) {
        return status.type;
      }

      return '';
    }

    function llmstats_field_supported(server, field) {
      var type = llmstats_effective_type(server);
      if (field === 'quant' || field === 'memory') return type === 'ollama';
      if (field === 'busy') return type === 'ollama' || type === 'llama-server';
      if (field === 'actions') {
        if (type === 'ollama') return true;
        if (type === 'llama-server') {
          var status = server ? statusById[server.id] : null;
          return !!(status && status.supportsModelActions);
        }
        return false;
      }
      return true;
    }

    function llmstats_supported_fields(server) {
      return fieldOrder.filter(function(field) {
        return llmstats_field_supported(server, field);
      });
    }

    function llmstats_filter_supported_fields(server) {
      if (!server) return;
      var supported = llmstats_supported_fields(server);
      server.fields = (server.fields || []).filter(function(field) {
        return supported.indexOf(field) !== -1;
      });
    }

    function llmstats_update_dirty_state() {
      $('#llmstats-unsaved-changes-bar').toggleClass('is-dirty', llmstatsDirty);
      $('#llmstats-unsaved-changes-message').text(
        llmstatsDirty
          ? 'Unsaved changes. Click Apply at the bottom to save them.'
          : 'No unsaved changes.'
      );
    }

    function llmstats_mark_dirty() {
      llmstatsDirty = true;
      llmstats_update_dirty_state();
    }

    function llmstats_update_required_state() {
      var issues = llmstats_server_issues(selectedServer);
      $('[data-required-field="name"]').toggleClass('is-invalid', !!issues.name);
      $('[data-required-field="url"]').toggleClass('is-invalid', !!issues.url);
      $('[data-required-field="type"]').toggleClass('is-invalid', !!issues.type);
      $('#llmstats-connection-validation').toggleClass('is-visible', llmstats_has_issues(selectedServer));
      $('#llmstats-apply')
        .prop('disabled', llmstats_has_invalid_servers())
        .attr('title', llmstats_has_invalid_servers() ? 'Fill all required server settings before applying.' : '');
    }

    function llmstats_row_type_text(server) {
      if (server.type !== 'auto') {
        return llmstats_type_label(server.type) + ' · manual';
      }
      var status = statusById[server.id];
      if (status && status.type) {
        return llmstats_type_label(status.type) + ' · auto';
      }
      return 'auto';
    }

    function llmstats_row_state(server) {
      if (llmstats_has_issues(server)) {
        return { dot: '', text: 'required' };
      }
      var status = statusById[server.id];
      if (!server.id || !status) {
        return { dot: '', text: 'unsaved' };
      }
      return { dot: status.dot || 'offline', text: (status.statusLabel || 'offline').toLowerCase() };
    }

    function llmstats_update_status_count() {
      var online = 0;
      servers.forEach(function(server) {
        var status = statusById[server.id];
        if (status && status.status === 'online' && !llmstats_has_issues(server)) online++;
      });
      $('#llmstats-status-count').text(online + ' online');
    }

    function llmstats_build_row(server, index) {
      var row = $('<div>')
        .addClass('llm-server-row')
        .attr('tabindex', '0')
        .attr('data-index', index)
        .toggleClass('is-selected', server === selectedServer);

      $('<button>')
        .attr('type', 'button')
        .addClass('llm-drag-handle')
        .attr('title', 'Drag to reorder')
        .attr('aria-label', 'Drag ' + (server.name || 'server') + ' to reorder')
        .append($('<i>').addClass('fa fa-bars').attr('aria-hidden', 'true'))
        .appendTo(row);

      var state = llmstats_row_state(server);
      $('<span>').addClass('llm-server-dot').addClass(state.dot).appendTo(row);
      $('<span>').addClass('llm-server-name').text(llmstats_display_name(server)).appendTo(row);
      $('<span>').addClass('llm-server-url').text(server.url || 'URL required').appendTo(row);
      $('<span>').addClass('llm-server-type').text(llmstats_row_type_text(server)).appendTo(row);
      $('<span>').addClass('llm-server-state').text(state.text).appendTo(row);

      var actions = $('<span>').addClass('llm-order-actions');
      $('<button>')
        .attr('type', 'button')
        .addClass('llm-row-action llm-move-server')
        .attr('data-direction', 'up')
        .attr('title', 'Move up')
        .attr('aria-label', 'Move ' + (server.name || 'server') + ' up')
        .append($('<i>').addClass('fa fa-arrow-up').attr('aria-hidden', 'true'))
        .appendTo(actions);
      $('<button>')
        .attr('type', 'button')
        .addClass('llm-row-action llm-move-server')
        .attr('data-direction', 'down')
        .attr('title', 'Move down')
        .attr('aria-label', 'Move ' + (server.name || 'server') + ' down')
        .append($('<i>').addClass('fa fa-arrow-down').attr('aria-hidden', 'true'))
        .appendTo(actions);
      $('<button>')
        .attr('type', 'button')
        .addClass('llm-row-action llm-remove-server')
        .attr('title', 'Remove server')
        .attr('aria-label', 'Remove ' + (server.name || 'server'))
        .append($('<i>').addClass('fa fa-times').attr('aria-hidden', 'true'))
        .appendTo(actions);
      actions.appendTo(row);

      return row;
    }

    function llmstats_render_list() {
      var list = $('#llmstats-server-list');
      list.empty();

      if (servers.length === 0) {
        list.append($('<p>').addClass('llm-empty-state').text('No servers configured yet. Click "Add Server" to add an Ollama or llama-server endpoint.'));
        return;
      }

      servers.forEach(function(server, index) {
        list.append(llmstats_build_row(server, index));
      });
    }

    function llmstats_update_preview() {
      var previewValues = {
        quant: 'Q4_K_M',
        memory: '4.9 GB',
        busy: 'Idle'
      };
      var enabled = { model: true };
      (selectedServer ? selectedServer.fields || [] : []).forEach(function(field) {
        enabled[field] = true;
      });

      var visiblePropCount = 0;
      var actionsVisible = false;
      $('#llmstats-preview-card [data-preview-field-cell]').each(function() {
        var cell = $(this);
        var field = cell.attr('data-preview-field-cell');
        var supported = selectedServer ? llmstats_field_supported(selectedServer, field) : false;
        var visible = !!enabled[field] && supported;
        cell.css('display', visible ? '' : 'none');
        cell.toggleClass('is-disabled', !supported);
        cell.find('[data-preview-item="' + field + '"]').text(supported ? previewValues[field] : 'Not supported');
        if (field === 'actions') {
          actionsVisible = visible;
        } else if (visible) {
          visiblePropCount++;
        }
      });

      var propColumns = visiblePropCount > 0
        ? ' repeat(' + visiblePropCount + ', minmax(90px, 1fr))'
        : ' ';
      var actionColumn = actionsVisible ? ' minmax(112px, 0.7fr)' : '';
      $('#llmstats-preview-card')
        .css('grid-template-columns', 'minmax(160px, 1.45fr)' + propColumns + actionColumn);

      $('#llmstats-preview-help').text(
        llmstats_effective_type(selectedServer) === 'llama-server'
          ? 'Preview for the selected fields supported by this server mode.'
          : 'Preview for the currently selected server and its supported fields.'
      );
    }

    function llmstats_sync_detail() {
      var hasSelection = !!selectedServer;
      $('#llmstats-server-name, #llmstats-server-url, #llmstats-server-type').prop('disabled', !hasSelection);
      $('.llmstats-field-toggle').prop('disabled', !hasSelection);

      $('.llmstats-selected-server-name').text(hasSelection ? llmstats_display_name(selectedServer) : '-');

      if (!hasSelection) {
        $('#llmstats-server-name').val('');
        $('#llmstats-server-url').val('');
        $('#llmstats-server-type').val('auto');
        $('.llmstats-field-toggle').prop('checked', false);
        llmstats_update_preview();
        llmstats_update_required_state();
        llmstats_update_dirty_state();
        return;
      }

      $('#llmstats-server-name').val(selectedServer.name || '');
      $('#llmstats-server-url').val(selectedServer.url || '');
      $('#llmstats-server-type').val(selectedServer.type || 'auto');

      $('.llmstats-field-toggle').each(function() {
        var toggle = $(this);
        var field = toggle.attr('data-preview-field');
        var supported = llmstats_field_supported(selectedServer, field);
        var row = $('[data-field-row="' + field + '"]');
        toggle
          .prop('disabled', !supported)
          .prop('checked', supported && (selectedServer.fields || []).indexOf(field) !== -1);
        row.toggleClass('is-disabled', !supported);
        $('[data-field-note="' + field + '"]').text(
          !supported
            ? 'not supported'
            : (field === 'busy' ? 'default' : (field === 'actions' ? 'optional' : 'Ollama only'))
        );
      });

      llmstats_update_preview();
      llmstats_update_required_state();
      llmstats_update_dirty_state();
    }

    function llmstats_select_index(index) {
      selectedServer = (index >= 0 && index < servers.length) ? servers[index] : null;
      $('#llmstats-test-result').text('').removeClass('is-online is-offline');
      llmstats_render_list();
      llmstats_sync_detail();
    }

    function llmstats_refresh_row_texts() {
      var index = servers.indexOf(selectedServer);
      if (index === -1) return;

      var row = $('#llmstats-server-list .llm-server-row[data-index="' + index + '"]');
      row.find('.llm-server-name').text(llmstats_display_name(selectedServer));
      row.find('.llm-server-url').text(selectedServer.url || 'URL required');
      row.find('.llm-server-type').text(llmstats_row_type_text(selectedServer));
      row.find('.llm-server-state').text(llmstats_row_state(selectedServer).text);
      $('.llmstats-selected-server-name').text(llmstats_display_name(selectedServer));
      llmstats_update_status_count();
      llmstats_update_required_state();
    }

    function llmstats_fetch_states() {
      $.ajax({
        url: '/plugins/llmstats/llmstats_api.php?action=get_server_states',
        dataType: 'json',
        timeout: 20000
      }).done(function(data) {
        statusById = {};
        ((data && data.servers) || []).forEach(function(state) {
          statusById[state.id] = state;
        });
        llmstats_render_list();
        llmstats_update_status_count();
        llmstats_sync_detail();
      }).fail(function() {
        $('#llmstats-status-count').text('status unavailable');
      });
    }

    function llmstats_apply_reorder() {
      var ordered = [];
      $('#llmstats-server-list .llm-server-row').each(function() {
        var index = parseInt($(this).attr('data-index'), 10);
        if (!isNaN(index) && servers[index]) {
          ordered.push(servers[index]);
        }
      });

      if (ordered.length === servers.length) {
        servers = ordered;
      }
      llmstats_mark_dirty();
      llmstats_serialize();
      llmstats_render_list();
    }

    var armedDragRow = null;
    var draggedRow = null;

    function llmstats_enable_row_drag(row) {
      if (!row) return;
      armedDragRow = row;
      row.setAttribute('draggable', 'true');
    }

    function llmstats_disable_row_drag(row) {
      if (!row) return;
      row.removeAttribute('draggable');
      if (armedDragRow === row) {
        armedDragRow = null;
      }
    }

    function llmstats_get_drag_after_element(container, y) {
      var rows = Array.prototype.slice.call(container.querySelectorAll('.llm-server-row:not(.is-dragging)'));
      return rows.reduce(function(closest, row) {
        var box = row.getBoundingClientRect();
        var offset = y - box.top - box.height / 2;
        if (offset < 0 && offset > closest.offset) {
          return { offset: offset, element: row };
        }
        return closest;
      }, { offset: Number.NEGATIVE_INFINITY, element: null }).element;
    }

    function llmstats_bind_server_list() {
      var list = document.getElementById('llmstats-server-list');
      if (!list) return;

      list.addEventListener('pointerdown', function(event) {
        var handle = event.target.closest('.llm-drag-handle');
        if (!handle) return;
        llmstats_enable_row_drag(handle.closest('.llm-server-row'));
      });

      list.addEventListener('dragstart', function(event) {
        var row = event.target.closest('.llm-server-row');
        if (!row || (row !== armedDragRow && !event.target.closest('.llm-drag-handle'))) {
          event.preventDefault();
          return;
        }

        draggedRow = row;
        row.classList.add('is-dragging');
        event.dataTransfer.effectAllowed = 'move';
        event.dataTransfer.setData('text/plain', row.getAttribute('data-index') || '');
      });

      list.addEventListener('dragover', function(event) {
        if (!draggedRow) return;
        event.preventDefault();

        var afterElement = llmstats_get_drag_after_element(list, event.clientY);
        if (afterElement) {
          list.insertBefore(draggedRow, afterElement);
        } else {
          list.appendChild(draggedRow);
        }
      });

      list.addEventListener('dragend', function() {
        if (draggedRow) {
          draggedRow.classList.remove('is-dragging');
          llmstats_disable_row_drag(draggedRow);
          draggedRow = null;
          llmstats_apply_reorder();
        }
      });

      list.addEventListener('drop', function(event) {
        event.preventDefault();
        if (draggedRow) {
          llmstats_disable_row_drag(draggedRow);
        }
      });

      list.addEventListener('pointerup', function() {
        if (!draggedRow && armedDragRow) {
          llmstats_disable_row_drag(armedDragRow);
        }
      });

      $(list).on('click', '.llm-server-row', function(event) {
        if ($(event.target).closest('.llm-row-action, .llm-drag-handle').length > 0) return;
        llmstats_select_index(parseInt($(this).attr('data-index'), 10));
      });

      $(list).on('keydown', '.llm-server-row', function(event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          llmstats_select_index(parseInt($(this).attr('data-index'), 10));
        }
      });

      $(list).on('click', '.llm-move-server', function(event) {
        event.stopPropagation();
        var index = parseInt($(this).closest('.llm-server-row').attr('data-index'), 10);
        var direction = $(this).attr('data-direction') === 'up' ? -1 : 1;
        var target = index + direction;
        if (isNaN(index) || target < 0 || target >= servers.length) return;

        var moved = servers.splice(index, 1)[0];
        servers.splice(target, 0, moved);
        llmstats_mark_dirty();
        llmstats_serialize();
        llmstats_render_list();
      });

      $(list).on('click', '.llm-remove-server', function(event) {
        event.stopPropagation();
        var index = parseInt($(this).closest('.llm-server-row').attr('data-index'), 10);
        var server = servers[index];
        if (!server) return;

        if (!window.confirm('Remove "' + (server.name || 'server') + '" from LLMStats?')) return;

        servers.splice(index, 1);
        if (selectedServer === server) {
          selectedServer = servers.length > 0 ? servers[Math.min(index, servers.length - 1)] : null;
        }
        llmstats_mark_dirty();
        llmstats_serialize();
        llmstats_render_list();
        llmstats_sync_detail();
        llmstats_update_status_count();
      });
    }

    $(function() {
      llmstats_serialize();
      llmstats_render_list();
      llmstats_sync_detail();
      llmstats_bind_server_list();
      llmstats_fetch_states();

      $('#llmstats-server-name').on('input', function() {
        if (!selectedServer) return;
        selectedServer.name = $(this).val();
        llmstats_mark_dirty();
        llmstats_serialize();
        llmstats_refresh_row_texts();
      });

      $('#llmstats-server-url').on('input', function() {
        if (!selectedServer) return;
        selectedServer.url = $.trim($(this).val());
        llmstats_mark_dirty();
        llmstats_serialize();
        llmstats_refresh_row_texts();
      });

      $('#llmstats-server-type').on('change', function() {
        if (!selectedServer) return;
        selectedServer.type = $(this).val();
        llmstats_filter_supported_fields(selectedServer);
        llmstats_mark_dirty();
        llmstats_serialize();
        llmstats_refresh_row_texts();
        llmstats_sync_detail();
      });

      $('.llmstats-field-toggle').on('change', function() {
        if (!selectedServer) return;

        var enabled = {};
        $('.llmstats-field-toggle').each(function() {
          var toggle = $(this);
          if (toggle.prop('checked')) {
            enabled[toggle.attr('data-preview-field')] = true;
          }
        });

        selectedServer.fields = fieldOrder.filter(function(field) {
          return !!enabled[field];
        });
        llmstats_filter_supported_fields(selectedServer);

        llmstats_mark_dirty();
        llmstats_serialize();
        llmstats_update_preview();
      });

      $('#llmstats-add-server').on('click', function() {
        if (servers.length >= maxServers) {
          window.alert('A maximum of ' + maxServers + ' servers is supported.');
          return;
        }

        var server = {
          id: '',
          name: '',
          url: '',
          type: 'auto',
          fields: defaultFields.slice()
        };
        llmstats_filter_supported_fields(server);
        servers.push(server);
        selectedServer = server;
        llmstats_mark_dirty();
        llmstats_serialize();
        llmstats_render_list();
        llmstats_sync_detail();
        $('#llmstats-server-name').focus();
      });

      $('#llmstats-test-server').on('click', function() {
        if (!selectedServer || testRequest) return;

        var result = $('#llmstats-test-result');
        if (llmstats_has_issues(selectedServer)) {
          llmstats_update_required_state();
          result.removeClass('is-online').addClass('is-offline').text('Fill required settings before testing.');
          return;
        }

        result.removeClass('is-online is-offline').text('testing…');

        testRequest = $.ajax({
          url: '/plugins/llmstats/llmstats_api.php',
          data: {
            action: 'test_server',
            url: selectedServer.url || '',
            type: selectedServer.type || 'auto'
          },
          dataType: 'json',
          timeout: 20000
        }).done(function(response) {
          if (!response) {
            result.addClass('is-offline').text('Test failed.');
            return;
          }
          if (response.ok) {
            var detail = response.typeLabel + (selectedServer.type === 'auto' ? ' (detected)' : '');
            result.addClass('is-online').text('Online · ' + detail + ' · ' + response.modelCount + ' models');
          } else {
            var error = response.error || response.statusLabel || 'Unreachable';
            result.addClass('is-offline').text((response.statusLabel || 'Offline') + ' - ' + error);
          }
        }).fail(function() {
          result.addClass('is-offline').text('Test failed.');
        }).always(function() {
          testRequest = null;
        });
      });

      $('form[name="llmstats_settings"]').on('submit', function(event) {
        if (llmstats_has_invalid_servers()) {
          event.preventDefault();
          llmstats_update_required_state();
          $('#llmstats-test-result')
            .removeClass('is-online')
            .addClass('is-offline')
            .text('Apply blocked - fill required server settings first.');
          return false;
        }

        llmstats_serialize();
      });
    });
  })(jQuery);
</script>
