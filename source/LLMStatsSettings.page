<?php
require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';
require_once '/usr/local/emhttp/plugins/llmstats/llmstats_common.php';

$plugin_name = 'llmstats';
$cfg_file = "/boot/config/plugins/{$plugin_name}/{$plugin_name}.cfg";
$default_cfg = llmstats_default_cfg();
$csrf_token = htmlspecialchars(llmstats_csrf_token(), ENT_QUOTES, 'UTF-8');

function llmstats_escape_cfg_value($value)
{
    $value = (string)$value;
    $value = preg_replace('/[\x00-\x1F\x7F]/', '', $value);
    if (!is_string($value)) {
        $value = '';
    }

    return str_replace(['\\', '"'], ['\\\\', '\\"'], $value);
}

function llmstats_write_cfg($path, $cfg)
{
    $lines = [];
    foreach ($cfg as $key => $value) {
        $safe_key = preg_replace('/[^A-Z0-9_]/', '', (string)$key);
        if (!is_string($safe_key) || $safe_key === '') {
            continue;
        }
        $lines[] = $safe_key . '="' . llmstats_escape_cfg_value($value) . '"';
    }

    $payload = implode("\n", $lines) . "\n";
    $dir = dirname($path);
    if (!is_dir($dir) && !@mkdir($dir, 0755, true)) {
        return false;
    }

    $tmp_path = @tempnam($dir, basename($path) . '.tmp.');
    if (!is_string($tmp_path) || $tmp_path === '') {
        return false;
    }

    $written = @file_put_contents($tmp_path, $payload, LOCK_EX);
    if ($written === false || !@rename($tmp_path, $path)) {
        @unlink($tmp_path);
        return false;
    }

    return true;
}

$cfg = llmstats_read_cfg($plugin_name);
$llmstats_theme_light = llmstats_theme_is_light();

$save_error = '';

if (isset($_POST['#apply'])) {
    $refresh_enabled = (isset($_POST['REFRESH_ENABLED']) && $_POST['REFRESH_ENABLED'] === '0') ? '0' : '1';
    $refresh_interval_input = isset($_POST['REFRESH_INTERVAL']) ? trim((string)$_POST['REFRESH_INTERVAL']) : $default_cfg['REFRESH_INTERVAL'];
    $refresh_interval = llmstats_clamp_refresh_interval(ctype_digit($refresh_interval_input) ? (int)$refresh_interval_input : 10);
    $confirm_unload = isset($_POST['CONFIRM_UNLOAD']) ? '1' : '0';

    $servers_payload = isset($_POST['SERVERS_PAYLOAD']) ? (string)$_POST['SERVERS_PAYLOAD'] : '';
    $decoded_servers = json_decode($servers_payload, true);

    if (!is_array($decoded_servers)) {
        $selected_servers = llmstats_parse_servers($cfg['SERVERS'] ?? '');
        if ($servers_payload !== '') {
            $save_error = 'Server list could not be read and was left unchanged.';
        }
    } else {
        $selected_servers = llmstats_normalize_server_list($decoded_servers);
        $dropped = count($decoded_servers) - count($selected_servers);
        if ($dropped > 0) {
            $save_error = $dropped . ' server entr' . ($dropped === 1 ? 'y was' : 'ies were')
                . ' not saved. Server URLs must start with http:// or https://.';
        }
    }

    $new_cfg = [
        'REFRESH_ENABLED' => $refresh_enabled,
        'REFRESH_INTERVAL' => (string)$refresh_interval,
        'CONFIRM_UNLOAD' => $confirm_unload,
        'SERVERS' => llmstats_encode_servers($selected_servers)
    ];

    if (llmstats_write_cfg($cfg_file, $new_cfg)) {
        $cfg = array_merge($default_cfg, $new_cfg);
        // Redirect-after-POST so a browser refresh does not re-apply the form.
        // Skipped when there is a warning to show or output already started.
        if ($save_error === '' && !headers_sent()) {
            header('Location: ' . ($_SERVER['REQUEST_URI'] ?? '/Settings/LLMStatsSettings'), true, 303);
            exit;
        }
    } elseif ($save_error === '') {
        $save_error = 'Unable to save settings.';
    }
}

$servers = llmstats_parse_servers($cfg['SERVERS'] ?? '');
$servers_js = json_encode($servers, llmstats_json_options());
if (!is_string($servers_js)) {
    $servers_js = '[]';
}
$default_fields_js = json_encode(llmstats_default_model_fields(), llmstats_json_options());
if (!is_string($default_fields_js)) {
    $default_fields_js = '[]';
}
$field_order_js = json_encode(array_keys(llmstats_model_fields()), llmstats_json_options());
if (!is_string($field_order_js)) {
    $field_order_js = '[]';
}
