    'loadUnavailable' => llmstats_t('Loading this model is not supported by this server mode.'),
    'unload' => llmstats_t('Unload'),
    'unloadAll' => llmstats_t('Unload all loaded'),
    'confirmUnload' => llmstats_t('Unload %1 from %2?'),
