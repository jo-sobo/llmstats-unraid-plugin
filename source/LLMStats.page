<script type="text/javascript">
    (function($) {
    var llmstatsText = <?=$llmstats_text_js?>;
    var refreshEnabled = <?=json_encode($refresh_enabled)?>;
    var refreshInterval = <?=json_encode($refresh_interval_ms)?>;
    var llmstatsCsrf = <?=$llmstats_csrf?>;
    var llmstatsRequest = null;
    var llmstatsActionPending = false;
    var llmstatsConfirmUnload = true;
    var llmstatsServersById = {};
    var llmstatsModelScrollByServer = {};
    var llmstatsPanelCache = {};

    var llmstatsPropOrder = [
        { field: 'quant', prop: 'quant', label: 'Quant' },
        { field: 'memory', prop: 'memory', label: 'Memory' },
        { field: 'busy', prop: 'state', label: 'State' }
    ];

    function llmstats_text(key, fallback) {
        return llmstatsText && llmstatsText[key] ? llmstatsText[key] : fallback;
    }

    function llmstats_format(template, values) {
        var result = String(template || '');
        (values || []).forEach(function(value, index) {
            result = result.replace('%' + (index + 1), value);
        });
        return result;
    }

    function llmstats_get_csrf_token() {
        if (typeof window.csrf_token === 'string' && window.csrf_token) {
            return window.csrf_token;
        }
        if (typeof window.csrfToken === 'string' && window.csrfToken) {
            return window.csrfToken;
        }
        var fieldToken = $('input[name="csrf_token"]').first().val();
        return fieldToken ? String(fieldToken) : llmstatsCsrf;
    }

    function llmstats_tab_class(server) {
        return server.status === 'online' ? 'is-online' : 'is-offline';
    }

    function llmstats_build_chips(servers) {
        var chips = $('#llmstats-chips');
        chips.empty();
        (servers || []).forEach(function(server) {
            var chip = $('<div>')
                .addClass('llm-chip')
                .addClass(server.status === 'online' ? 'is-online' : 'is-offline');
            $('<span>').addClass('llm-dot').addClass(server.dot || 'offline').appendTo(chip);
            $('<span>').addClass('llm-chip-name').text(server.name || '').appendTo(chip);
            $('<span>').addClass('llm-chip-meta').text(server.chipMeta || '').appendTo(chip);
            chips.append(chip);
        });
    }

    function llmstats_update_tab_edge_fades() {
        var tabShell = document.getElementById('llmstats-tab-shell');
        var tabBar = document.getElementById('llmstats-tab-bar');
        if (!tabShell || !tabBar) return;

        var maxScroll = tabBar.scrollWidth - tabBar.clientWidth;
        tabShell.classList.toggle('has-left-overflow', tabBar.scrollLeft > 1);
        tabShell.classList.toggle('has-right-overflow', maxScroll - tabBar.scrollLeft > 1);
    }

    function llmstats_find_tab(tabBar, serverId) {
        return tabBar.find('.llm-tab').filter(function() {
            return $(this).data('server-id') === serverId;
        }).first();
    }

    function llmstats_place_tab(tabBar, tab, index) {
        var tabEl = tab[0];
        var currentEl = tabBar.children('.llm-tab').get(index);
        if (currentEl === tabEl) return;

        if (currentEl) {
            tab.insertBefore(currentEl);
        } else if (tabEl.parentNode !== tabBar[0] || tabEl !== tabBar.children('.llm-tab').last()[0]) {
            tabBar[0].appendChild(tabEl);
        }
    }

    function llmstats_update_tabs(servers) {
        var tabBar = $('#llmstats-tab-bar');
        var seen = {};

        (servers || []).forEach(function(server, index) {
            var tab = llmstats_find_tab(tabBar, server.id);

            if (tab.length === 0) {
                tab = $('<div>')
                    .addClass('llm-tab')
                    .attr('role', 'tab')
                    .attr('tabindex', '-1')
                    .attr('aria-selected', 'false');

                $('<span>').addClass('llm-tab-status-mark').appendTo(tab);
                $('<span>').addClass('llm-tab-selected-mark').appendTo(tab);
                $('<span>').addClass('llm-tab-label').appendTo(tab);
            }

            seen[server.id] = true;
            tab.removeClass('is-online is-offline')
                .addClass(llmstats_tab_class(server))
                .data('server-id', server.id)
                .attr('id', 'llmstats-tab-' + server.id)
                .attr('aria-controls', 'llmstats-panel-' + server.id)
                .attr('aria-label', server.name || '');

            var label = tab.find('.llm-tab-label');
            if (label.text() !== (server.name || '')) {
                label.text(server.name || '');
            }

            llmstats_place_tab(tabBar, tab, index);
        });

        tabBar.find('.llm-tab').each(function() {
            var tab = $(this);
            if (!seen[tab.data('server-id')]) {
                tab.remove();
            }
        });
    }

    function llmstats_build_status_card(server) {
        var card = $('<div>').addClass('llm-server-status');

        var nameCell = $('<div>').addClass('llm-status-cell');
        var nameRow = $('<div>').addClass('llm-status-name');
        $('<span>').addClass('llm-dot').addClass(server.dot || 'offline').appendTo(nameRow);
        nameRow.append(document.createTextNode(server.name || ''));
        nameCell.append(nameRow);
        $('<div>').addClass('llm-status-url').text(server.url || '').appendTo(nameCell);
        card.append(nameCell);

        (server.summary || []).slice(0, 4).forEach(function(cell) {
            var statusCell = $('<div>').addClass('llm-status-cell');
            $('<div>').addClass('llm-label').text(cell.label || '').appendTo(statusCell);
            $('<div>').addClass('llm-value').text(cell.value || '').appendTo(statusCell);
            card.append(statusCell);
        });

        return card;
    }

    function llmstats_enabled_props(server) {
        var fields = server.fields || [];
        return llmstatsPropOrder.filter(function(entry) {
            return fields.indexOf(entry.field) !== -1;
        });
    }

    function llmstats_model_actions_enabled(server) {
        var fields = server && server.fields ? server.fields : [];
        return fields.indexOf('actions') !== -1 && !!(server && server.supportsModelActions);
    }

    function llmstats_build_model_card(server, model, enabledProps) {
        var actionsEnabled = llmstats_model_actions_enabled(server);
        var card = $('<article>')
            .addClass('llm-model-card')
            .addClass('props-' + Math.min(enabledProps.length, 3))
            .toggleClass('has-actions', actionsEnabled);

        if (model.loaded) {
            card.addClass('is-loaded');
        }
        if (model.state === 'busy') {
            card.addClass('is-busy');
        }

        var main = $('<div>').addClass('llm-model-main');
        $('<h4>').addClass('llm-model-name').text(model.name || '').attr('title', model.name || '').appendTo(main);
        card.append(main);

        enabledProps.forEach(function(entry) {
            var prop = $('<div>').addClass('llm-model-prop');
            $('<div>').addClass('llm-label').text(entry.label).appendTo(prop);
            $('<div>').addClass('llm-value').text((model.props || {})[entry.prop] || 'Unavailable').appendTo(prop);
            card.append(prop);
        });

        if (actionsEnabled) {
            var actions = $('<div>').addClass('llm-model-actions');
            if (model.canUnload && model.loaded) {
                $('<button>')
                    .addClass('llm-button danger llm-model-action-button llmstats-unload-model')
                    .attr('type', 'button')
                    .attr('data-server-id', server.id)
                    .attr('data-model', model.name || '')
                    .text(llmstats_text('unload', 'Unload'))
                    .appendTo(actions);
            } else if (!model.loaded) {
                var canLoad = !!model.canLoad;
                var loadTitle = canLoad
                    ? ''
                    : (model.loadUnavailableReason || llmstats_text('loadUnavailable', 'Loading this model is not supported by this server mode.'));
                $('<button>')
                    .addClass('llm-button llm-model-action-button')
                    .toggleClass('llmstats-load-model', canLoad)
                    .toggleClass('llmstats-load-disabled', !canLoad)
                    .attr('type', 'button')
                    .attr('data-server-id', server.id)
                    .attr('data-model', model.name || '')
                    .prop('disabled', !canLoad)
                    .attr('title', loadTitle)
                    .text(llmstats_text('load', 'Load'))
                    .appendTo(actions);
            }
            card.append(actions);
        }

        return card;
    }

    function llmstats_save_model_scrolls() {
        $('#llmstats-panels').find('.llm-panel').each(function() {
            var panel = $(this);
            var list = panel.find('.llm-model-list');
            var serverId = panel.data('server-id');
            if (serverId && list.length > 0) {
                llmstatsModelScrollByServer[serverId] = list.scrollTop();
            }
        });
    }

    function llmstats_update_panels(servers) {
        var panels = $('#llmstats-panels');
        var seen = {};
        llmstats_save_model_scrolls();

        (servers || []).forEach(function(server) {
            seen[server.id] = true;
            var panelId = 'llmstats-panel-' + server.id;
            var panel = $('#' + panelId);

            // Skip the rebuild (and the scroll churn it causes) when nothing changed.
            var snapshot = JSON.stringify(server);
            if (panel.length > 0 && llmstatsPanelCache[server.id] === snapshot) {
                return;
            }
            llmstatsPanelCache[server.id] = snapshot;

            if (panel.length === 0) {
                panel = $('<section>')
                    .addClass('llm-panel')
                    .attr('id', panelId)
                    .attr('role', 'tabpanel')
                    .attr('aria-labelledby', 'llmstats-tab-' + server.id)
                    .data('server-id', server.id);
            }

            panel.empty();
            panel.append(llmstats_build_status_card(server));

            if (server.status !== 'online') {
                $('<div>').addClass('llm-empty').text(llmstats_text('offlineHint', 'This configured server is offline. Please check the settings or server for issues.')).appendTo(panel);
            } else if (!server.models || server.models.length === 0) {
                $('<div>').addClass('llm-empty').text(llmstats_text('noModels', 'No models found on this server.')).appendTo(panel);
            } else {
                var list = $('<div>').addClass('llm-model-list');
                var enabledProps = llmstats_enabled_props(server);
                server.models.forEach(function(model) {
                    list.append(llmstats_build_model_card(server, model, enabledProps));
                });
                panel.append(list);
                list.scrollTop(llmstatsModelScrollByServer[server.id] || 0);
            }

            panels.append(panel);
        });

        panels.find('.llm-panel').each(function() {
            var panel = $(this);
            var serverId = panel.data('server-id');
            if (!seen[serverId]) {
                panel.remove();
                delete llmstatsPanelCache[serverId];
                delete llmstatsModelScrollByServer[serverId];
            }
        });

        window.setTimeout(function() {
            panels.find('.llm-panel').each(function() {
                var panel = $(this);
                var list = panel.find('.llm-model-list');
                var serverId = panel.data('server-id');
                if (serverId && list.length > 0) {
                    list.scrollTop(llmstatsModelScrollByServer[serverId] || 0);
                }
            });
        }, 0);
    }

    function llmstats_update_unload_all_button() {
        var button = $('#llmstats-unload-all');
        var selectedId = $('#llmstats-tab-bar').find('.llm-tab.is-selected').data('server-id');
        var server = selectedId ? llmstatsServersById[selectedId] : null;
        var enabled = !!(server && server.status === 'online' && server.loadedCount > 0 && llmstats_model_actions_enabled(server) && !llmstatsActionPending);

        button.prop('disabled', !enabled);
        button.toggle(!!(server && llmstats_model_actions_enabled(server)));
        button.data('server-id', server ? server.id : '');
    }

    function llmstats_select_tab(tab) {
        var selectedTab = $(tab);
        if (selectedTab.length === 0) return;

        var tabBar = $('#llmstats-tab-bar');
        var serverId = selectedTab.data('server-id');

        tabBar.find('.llm-tab')
            .removeClass('is-selected')
            .attr('aria-selected', 'false')
            .attr('tabindex', '-1');

        selectedTab
            .addClass('is-selected')
            .attr('aria-selected', 'true')
            .attr('tabindex', '0');

        $('#llmstats-panels').find('.llm-panel').each(function() {
            var panel = $(this);
            panel.toggleClass('is-selected', panel.data('server-id') === serverId);
        });

        llmstats_update_unload_all_button();
    }

    function llmstats_render_empty_state(message) {
        $('#llmstats-tab-bar').empty();
        $('#llmstats-panels').empty().append($('<div>').addClass('llm-empty').text(message));
        llmstats_build_chips([]);
        llmstatsServersById = {};
        llmstatsPanelCache = {};
        llmstatsModelScrollByServer = {};
        llmstats_update_unload_all_button();
        $('#llmstats-timestamp').text(new Date().toLocaleTimeString());
        llmstats_update_tab_edge_fades();
    }

    function llmstats_handle_tab_keydown(event) {
        var tabBar = $('#llmstats-tab-bar');
        var tabs = tabBar.find('.llm-tab');
        var currentIndex = tabs.index(this);
        var targetIndex = currentIndex;

        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
            targetIndex = currentIndex + 1 >= tabs.length ? 0 : currentIndex + 1;
        } else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
            targetIndex = currentIndex - 1 < 0 ? tabs.length - 1 : currentIndex - 1;
        } else if (event.key === 'Home') {
            targetIndex = 0;
        } else if (event.key === 'End') {
            targetIndex = tabs.length - 1;
        } else if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            llmstats_select_tab($(this));
            return;
        } else {
            return;
        }

        event.preventDefault();
        tabs.eq(targetIndex).focus();
        llmstats_select_tab(tabs.eq(targetIndex));
    }

    function llmstats_status() {
        if (llmstatsRequest) {
            return llmstatsRequest;
        }

        llmstatsRequest = $.ajax({
            url: '/plugins/llmstats/llmstats_api.php?action=get_server_states',
            dataType: 'json',
            timeout: Math.max(refreshInterval * 2, 15000)
        }).done(function(data) {
            var servers = (data && Array.isArray(data.servers)) ? data.servers : [];
            llmstatsConfirmUnload = !data || data.confirmUnload !== false;

            if (servers.length === 0) {
                llmstats_render_empty_state(llmstats_text('noServers', 'No servers configured.'));
                return;
            }

            var tabBar = $('#llmstats-tab-bar');
            var previouslySelected = tabBar.find('.llm-tab.is-selected').data('server-id');

            llmstatsServersById = {};
            servers.forEach(function(server) {
                llmstatsServersById[server.id] = server;
            });

            llmstats_update_tabs(servers);
            llmstats_update_panels(servers);
            llmstats_build_chips(servers);

            var selectedTab = llmstats_find_tab(tabBar, previouslySelected);
            if (selectedTab.length > 0) {
                llmstats_select_tab(selectedTab);
            } else {
                llmstats_select_tab(tabBar.find('.llm-tab').first());
            }

            llmstats_update_tab_edge_fades();
            $('#llmstats-timestamp').text(new Date().toLocaleTimeString());
        }).fail(function(jqXHR, textStatus, errorThrown) {
            console.error('LLMStats AJAX Error:', textStatus, errorThrown);
            llmstatsPanelCache = {};
            $('#llmstats-panels').empty().append(
                $('<div>').addClass('llm-empty').text(llmstats_text('loadError', 'Error loading server states.'))
            );
        }).always(function() {
            llmstatsRequest = null;
        });

        return llmstatsRequest;
    }

    function llmstats_poll() {
        llmstats_status().always(function() {
            if (refreshEnabled && refreshInterval > 0) {
                setTimeout(llmstats_poll, refreshInterval);
            }
        });
    }

    function llmstats_run_action(data) {
        if (llmstatsActionPending) return;

        llmstatsActionPending = true;
        llmstats_update_unload_all_button();
        data.csrf_token = llmstats_get_csrf_token();

        $.ajax({
            url: '/plugins/llmstats/llmstats_api.php',
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: data,
            dataType: 'json',
            timeout: 65000
        }).done(function(response) {
            if (!response || response.ok !== true) {
                window.alert((response && response.error) ? response.error : llmstats_text('actionFailed', 'Unload request failed.'));
            }
        }).fail(function(xhr) {
            var message = llmstats_text('actionFailed', 'Unload request failed.');
            if (xhr && xhr.responseJSON && xhr.responseJSON.error) {
                message = xhr.responseJSON.error;
            } else if (xhr && xhr.responseText) {
                message = xhr.responseText.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
            } else if (xhr && xhr.status) {
                message = 'Unload request failed. HTTP ' + xhr.status;
            }
            window.alert(message);
        }).always(function() {
            llmstatsActionPending = false;
            window.setTimeout(llmstats_status, 1500);
        });
    }

    function llmstats_sync_collapsed_row() {
        var contentRow = document.getElementById('llmstats-content-row');
        var collapsedRow = document.getElementById('llmstats-collapsed-row');
        if (!contentRow || !collapsedRow) return;

        var isCollapsed = contentRow.style.display === 'none' || contentRow.hidden;
        collapsedRow.style.display = isCollapsed ? '' : 'none';
    }

    // Watch for Unraid's openClose toggling the content row, and swap in/out the chips row
    function llmstats_watch_collapse() {
        var contentRow = document.getElementById('llmstats-content-row');
        var collapsedRow = document.getElementById('llmstats-collapsed-row');
        if (!contentRow || !collapsedRow) return;

        llmstats_sync_collapsed_row();

        var observer = new MutationObserver(llmstats_sync_collapsed_row);

        observer.observe(contentRow, { attributes: true, attributeFilter: ['style', 'hidden'] });
    }

    $(function() {
        $('#llmstats-tab-bar')
            .on('click', '.llm-tab', function() {
                llmstats_select_tab($(this));
            })
            .on('keydown', '.llm-tab', llmstats_handle_tab_keydown)
            .on('scroll', llmstats_update_tab_edge_fades);

        $('#llmstats-panels').on('click', '.llmstats-unload-model', function() {
            var button = $(this);
            var serverId = button.attr('data-server-id');
            var model = button.attr('data-model');
            var server = llmstatsServersById[serverId];
            if (!server || !model) return;

            if (llmstatsConfirmUnload) {
                var message = llmstats_format(llmstats_text('confirmUnload', 'Unload %1 from %2?'), [model, server.name]);
                if (!window.confirm(message)) return;
            }

            llmstats_run_action({ action: 'unload_model', server: serverId, model: model });
        });

        $('#llmstats-panels').on('click', '.llmstats-load-model', function() {
            var button = $(this);
            var serverId = button.attr('data-server-id');
            var model = button.attr('data-model');
            var server = llmstatsServersById[serverId];
            if (!server || !model || button.prop('disabled')) return;

            llmstats_run_action({ action: 'load_model', server: serverId, model: model });
        });

        $('#llmstats-panels').on('scroll', '.llm-model-list', function() {
            var panel = $(this).closest('.llm-panel');
            var serverId = panel.data('server-id');
            if (serverId) {
                llmstatsModelScrollByServer[serverId] = $(this).scrollTop();
            }
        });

        $('#llmstats-unload-all').on('click', function() {
            var serverId = $(this).data('server-id');
            var server = llmstatsServersById[serverId];
            if (!server) return;

            if (llmstatsConfirmUnload) {
                var message = llmstats_format(llmstats_text('confirmUnloadAll', 'Unload all loaded models on %1?'), [server.name]);
                if (!window.confirm(message)) return;
            }

            llmstats_run_action({ action: 'unload_all', server: serverId });
        });

        $('#llmstats-refresh').on('click', function() {
            llmstats_status();
        });

        window.addEventListener('resize', llmstats_update_tab_edge_fades);

        llmstats_watch_collapse();

        if (refreshEnabled && refreshInterval > 0) {
            llmstats_poll();
        } else {
            llmstats_status();
        }
    });
    })(jQuery);
</script>
